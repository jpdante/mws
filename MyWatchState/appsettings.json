{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mywatchstate;Username=postgres;Password=postgres"
  },
  "Keycloak": {
    "Url": "http://localhost:8080",
    "Realm": "mywatchstate",
    "ClientId": "mywatchstate-extension",
    "AdminClientId": "mywatchstate-backend",
    "AdminClientSecret": ""
  },
  "AllowedOrigins": []
}
