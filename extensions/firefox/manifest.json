{
  "manifest_version": 3,
  "name": "MyWatchState",
  "version": "0.1.3",
  "description": "Track your video watch progress across websites.",
  "permissions": [
    "storage",
    "alarms",
    "identity"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://xhamster.com/*",
    "https://www.dailymotion.com/*",
    "https://geo.dailymotion.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/youtube/index.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://xhamster.com/*"],
      "js": ["content/xhamster/index.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.dailymotion.com/*"],
      "js": ["content/dailymotion/index.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://geo.dailymotion.com/*"],
      "js": ["content/dailymotion/player-frame.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "MyWatchState"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "mywatchstate@example.com",
      "strict_min_version": "128.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
